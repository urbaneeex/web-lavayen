---
/**
 * Ficha de proyecto: cabecera en dos columnas, galería con flechas y puntos,
 * navegación al proyecto anterior/siguiente (solo los que existan).
 *
 * `descriptionHtml` solo debe contener HTML de confianza (p. ej. desde works.ts);
 * si en el futuro viene de CMS, sanitizar antes de pasarlo a set:html.
 */
export interface WorkCardNavLink {
	title: string;
	href: string;
}

type GallerySlide = { src: string; alt: string; media?: 'image' | 'video' };

interface Props {
	title: string;
	year: string;
	descriptionHtml: string;
	images: GallerySlide[];
	/** Id estable del bloque galería (p. ej. slug del proyecto) */
	galleryRootId: string;
	prev?: WorkCardNavLink | null;
	next?: WorkCardNavLink | null;
}

const { title, year, descriptionHtml, images, galleryRootId, prev = null, next = null } = Astro.props;

function isVideoSlide(s: GallerySlide): boolean {
	return s.media === 'video' || /\.mp4($|\?)/i.test(s.src);
}

const TRANSPARENT_GIF =
	'data:image/gif;base64,R0lGODlhAQABAIAAAAAAAP///yH5BAEAAAAALAAAAAABAAEAAAIBRAA7';

const first = images[0]!;
const firstIsVideo = isVideoSlide(first);
const firstStatic = images.find((s) => !isVideoSlide(s));
const hasCarousel = images.length > 1;
const titleId = `work-title-${galleryRootId}`;
---

<section class="work-card" data-work-card aria-labelledby={titleId}>
	<header class="work-card-header">
		<div class="work-card-intro">
			<h1 class="work-card-title" id={titleId}>{title}</h1>
			<span class="work-card-year">{year}</span>
		</div>
		<div class="work-card-body prose" set:html={descriptionHtml} />
	</header>

	<div
		class:list={['work-card-gallery', !hasCarousel && 'work-card-gallery--single']}
		data-gallery-root
		id={galleryRootId}
		tabindex="0"
		aria-roledescription="carrusel"
		aria-label={`Imágenes de ${title}`}
	>
		<div class="work-card-gallery-frame">
			{
				hasCarousel ? (
					<>
						<button
							type="button"
							class="work-card-gallery-arrow work-card-gallery-arrow--prev"
							data-gallery-prev
							aria-label="Imagen anterior"
						>
							<span aria-hidden="true">‹</span>
						</button>
						<button
							type="button"
							class="work-card-gallery-arrow work-card-gallery-arrow--next"
							data-gallery-next
							aria-label="Imagen siguiente"
						>
							<span aria-hidden="true">›</span>
						</button>
					</>
				) : null
			}
			<figure class="work-card-gallery-figure">
				<img
					class="work-card-gallery-img"
					data-gallery-img
					hidden={firstIsVideo || undefined}
					src={firstIsVideo ? (firstStatic?.src ?? TRANSPARENT_GIF) : first.src}
					alt={firstIsVideo ? (firstStatic?.alt ?? first.alt) : first.alt}
					loading="eager"
					decoding="async"
					width="1600"
					height="900"
				/>
				<video
					class="work-card-gallery-video"
					data-gallery-video
					hidden={!firstIsVideo || undefined}
					src={firstIsVideo ? first.src : undefined}
					controls
					playsinline
					preload="metadata"
					width="1600"
					height="900"
					aria-label={firstIsVideo ? first.alt : 'Vídeo del proyecto'}
				>
				</video>
			</figure>
		</div>
		{
			hasCarousel ? (
				<div class="work-card-dots" data-gallery-dots role="group" aria-label="Seleccionar imagen de la galería">
					{images.map((_, i) => (
						<button
							type="button"
							class:list={['work-card-dot', i === 0 && 'is-active']}
							data-gallery-dot={i}
							aria-label={`Imagen ${i + 1} de ${images.length}`}
							aria-current={i === 0 ? 'true' : 'false'}
						/>
					))}
				</div>
			) : null
		}
	</div>

	<nav class="work-card-project-nav" aria-label="Proyecto anterior o siguiente">
		<div class="work-card-nav-prev">
			{
				prev ? (
					<a class="work-card-nav-link" href={prev.href}>
						<span class="work-card-nav-chevron" aria-hidden="true">‹</span>
						{prev.title}
					</a>
				) : null
			}
		</div>
		<div class="work-card-nav-next">
			{
				next ? (
					<a class="work-card-nav-link" href={next.href}>
						{next.title}
						<span class="work-card-nav-chevron" aria-hidden="true">›</span>
					</a>
				) : null
			}
		</div>
	</nav>
</section>

<script define:vars={{ images, galleryRootId }}>
	(function () {
		const root = document.getElementById(galleryRootId);
		if (!root || !images || images.length <= 1) return;

		const img = root.querySelector('[data-gallery-img]');
		const video = root.querySelector('[data-gallery-video]');
		const btnPrev = root.querySelector('[data-gallery-prev]');
		const btnNext = root.querySelector('[data-gallery-next]');
		const dots = root.querySelectorAll('[data-gallery-dot]');
		if (!(img instanceof HTMLImageElement) || !(video instanceof HTMLVideoElement)) return;

		function slideIsVideo(s) {
			return s.media === 'video' || /\.mp4($|\?)/i.test(s.src);
		}

		let index = 0;

		function setSlide(i) {
			index = (i + images.length) % images.length;
			const slide = images[index];
			if (slideIsVideo(slide)) {
				video.removeAttribute('hidden');
				video.src = slide.src;
				video.setAttribute('aria-label', slide.alt);
				video.load();
				img.setAttribute('hidden', '');
			} else {
				video.setAttribute('hidden', '');
				video.pause();
				video.removeAttribute('src');
				video.load();
				img.removeAttribute('hidden');
				img.src = slide.src;
				img.alt = slide.alt;
			}
			dots.forEach((dot, j) => {
				if (!(dot instanceof HTMLButtonElement)) return;
				const on = j === index;
				dot.classList.toggle('is-active', on);
				dot.setAttribute('aria-current', on ? 'true' : 'false');
			});
		}

		btnPrev?.addEventListener('click', () => setSlide(index - 1));
		btnNext?.addEventListener('click', () => setSlide(index + 1));
		dots.forEach((dot, j) => {
			dot.addEventListener('click', () => setSlide(j));
		});

		root.addEventListener('keydown', (e) => {
			if (images.length <= 1) return;
			if (e.key === 'ArrowLeft') {
				e.preventDefault();
				setSlide(index - 1);
			} else if (e.key === 'ArrowRight') {
				e.preventDefault();
				setSlide(index + 1);
			} else if (e.key === 'Home') {
				e.preventDefault();
				setSlide(0);
			} else if (e.key === 'End') {
				e.preventDefault();
				setSlide(images.length - 1);
			}
		});
	})();
</script>

<style>
	/* Mismo ancho útil que el header: el padre (.work-detail-page / .work-page) ya usa calc(100% - 2 * --site-pad) */
	.work-card {
		width: 100%;
		max-width: none;
		margin: 0;
		padding: 0;
		color: #f5f5f5;
	}

	.work-card-header {
		display: grid;
		grid-template-columns: minmax(0, 0.88fr) minmax(0, 1.12fr);
		gap: clamp(1.5rem, 4vw, 3.25rem);
		align-items: start;
		margin-bottom: clamp(2rem, 5vw, 3rem);
	}

	.work-card-intro {
		display: flex;
		flex-direction: column;
		gap: 0.85rem;
	}

	.work-card-title {
		margin: 0;
		font-family: 'Instrument Serif', Georgia, serif;
		font-size: clamp(2rem, 5.2vw, 3.35rem);
		font-weight: 400;
		line-height: 1.05;
		letter-spacing: -0.02em;
		color: #fff;
	}

	.work-card-year {
		width: fit-content;
		padding: 0.1rem 0.42rem;
		font-family: Inter, system-ui, sans-serif;
		font-size: 0.78rem;
		color: rgba(239, 239, 239, 0.92);
		border: 1px solid rgba(255, 255, 255, 0.22);
		border-radius: 0.2rem;
		line-height: 1.2;
	}

	.work-card-body {
		font-family: Inter, system-ui, sans-serif;
		font-size: clamp(0.86rem, 1.05vw, 0.96rem);
		line-height: 1.42;
		color: rgba(245, 245, 245, 0.88);
		text-align: justify;
		hyphens: auto;
		text-wrap: pretty;
	}

	.work-card-body :global(p) {
		margin: 0 0 0.75rem;
	}

	.work-card-body :global(p:last-child) {
		margin-bottom: 0;
	}

	.work-card-body :global(strong) {
		font-weight: 600;
		color: #fff;
	}

	.work-card-gallery {
		margin-bottom: 1.25rem;
	}

	.work-card-gallery:focus-visible {
		outline: 2px solid rgba(255, 255, 255, 0.45);
		outline-offset: 4px;
	}

	.work-card-gallery-frame {
		position: relative;
		background: #111;
		overflow: hidden;
		aspect-ratio: 16 / 9;
	}

	.work-card-gallery-figure {
		margin: 0;
		width: 100%;
		height: 100%;
	}

	.work-card-gallery-img {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.work-card-gallery-img[hidden] {
		display: none;
	}

	.work-card-gallery-video {
		display: block;
		width: 100%;
		height: 100%;
		object-fit: cover;
	}

	.work-card-gallery-video[hidden] {
		display: none;
	}

	.work-card-gallery-arrow {
		position: absolute;
		top: 50%;
		transform: translateY(-50%);
		z-index: 2;
		width: 3rem;
		height: 4.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
		margin: 0;
		padding: 0;
		border: none;
		background: transparent;
		color: #fff;
		font-size: 2.25rem;
		line-height: 1;
		cursor: pointer;
		opacity: 0.88;
		transition: opacity 160ms ease;
	}

	.work-card-gallery-arrow:hover {
		opacity: 1;
	}

	.work-card-gallery-arrow:focus-visible {
		outline: 2px solid rgba(255, 255, 255, 0.5);
		outline-offset: 2px;
	}

	.work-card-gallery-arrow--prev {
		left: 0.15rem;
	}

	.work-card-gallery-arrow--next {
		right: 0.15rem;
	}

	.work-card-dots {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: 0.45rem;
		margin-top: 1rem;
	}

	.work-card-dot {
		width: 6px;
		height: 6px;
		padding: 0;
		border: none;
		border-radius: 999px;
		background: rgba(255, 255, 255, 0.28);
		cursor: pointer;
		transition:
			background 160ms ease,
			transform 160ms ease;
	}

	.work-card-dot.is-active {
		background: #fff;
		transform: scale(1.15);
	}

	.work-card-dot:focus-visible {
		outline: 2px solid rgba(255, 255, 255, 0.45);
		outline-offset: 3px;
	}

	.work-card-project-nav {
		display: flex;
		justify-content: space-between;
		align-items: baseline;
		gap: 1.5rem;
		padding-bottom: 0.25rem;
	}

	.work-card-nav-prev,
	.work-card-nav-next {
		min-width: 0;
		flex: 0 1 auto;
	}

	.work-card-nav-next {
		text-align: right;
		margin-left: auto;
	}

	.work-card-nav-link {
		font-family: 'Instrument Serif', Georgia, serif;
		font-size: clamp(1.05rem, 2.2vw, 1.35rem);
		font-weight: 400;
		color: #fff;
		text-decoration: none;
		display: inline-flex;
		align-items: baseline;
		gap: 0.35rem;
		transition: opacity 160ms ease;
	}

	.work-card-nav-link:hover {
		opacity: 0.78;
	}

	.work-card-nav-chevron {
		font-size: 0.95em;
		opacity: 0.9;
	}

	@media (max-width: 720px) {
		.work-card-header {
			grid-template-columns: 1fr;
			gap: 1.35rem;
		}

		.work-card-body {
			text-align: start;
			hyphens: manual;
		}

		.work-card-gallery-arrow {
			width: 2.5rem;
			height: 3.5rem;
			font-size: 1.85rem;
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.work-card-gallery-arrow,
		.work-card-dot,
		.work-card-nav-link {
			transition: none;
		}
	}
</style>
