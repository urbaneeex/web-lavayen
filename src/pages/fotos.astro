---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import SlideFrameLink from '../components/SlideFrameLink.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_ORIGIN } from '../site';

const title = 'Fotografía y mirada creativa | Ángel Lavayen, Madrid';
const description =
	'Galería personal en blanco y negro de Ángel Alejandro Lavayen Ruiz: fotografía, composición y ojo de director de arte en Madrid.';
const canonicalURL = new URL(Astro.url.pathname, SITE_ORIGIN).toString();
const heroImg = '/images/foto-barco.webp';
const ogImage = new URL(heroImg, SITE_ORIGIN).href;

const fotos = [
	{ src: '/images/foto-01.webp', alt: 'Fotografía en blanco y negro — galería personal de Ángel Lavayen (1 de 14)' },
	{ src: '/images/foto-02.webp', alt: 'Fotografía en blanco y negro — galería personal de Ángel Lavayen (2 de 14)' },
	{ src: '/images/foto-03.webp', alt: 'Fotografía en blanco y negro — galería personal de Ángel Lavayen (3 de 14)' },
	{ src: '/images/foto-04.webp', alt: 'Fotografía en blanco y negro — galería personal de Ángel Lavayen (4 de 14)' },
	{ src: '/images/foto-05.webp', alt: 'Fotografía en blanco y negro — galería personal de Ángel Lavayen (5 de 14)' },
	{ src: '/images/foto-06.webp', alt: 'Fotografía en blanco y negro — galería personal de Ángel Lavayen (6 de 14)' },
	{ src: '/images/foto-07.webp', alt: 'Fotografía en blanco y negro — galería personal de Ángel Lavayen (7 de 14)' },
	{ src: '/images/foto-08.webp', alt: 'Fotografía en blanco y negro — galería personal de Ángel Lavayen (8 de 14)' },
	{ src: '/images/foto-09.webp', alt: 'Fotografía en blanco y negro — galería personal de Ángel Lavayen (9 de 14)' },
	{ src: '/images/foto-10.webp', alt: 'Fotografía en blanco y negro — galería personal de Ángel Lavayen (10 de 14)' },
	{ src: '/images/foto-11.webp', alt: 'Fotografía en blanco y negro — galería personal de Ángel Lavayen (11 de 14)' },
	{ src: '/images/foto-12.webp', alt: 'Fotografía en blanco y negro — galería personal de Ángel Lavayen (12 de 14)' },
	{ src: '/images/foto-13.webp', alt: 'Fotografía en blanco y negro — galería personal de Ángel Lavayen (13 de 14)' },
	{ src: '/images/foto-14.webp', alt: 'Fotografía en blanco y negro — galería personal de Ángel Lavayen (14 de 14)' }
];
---

<BaseLayout
	title={title}
	description={description}
	canonicalURL={canonicalURL}
	ogImage={ogImage}
	ogLocaleAlternate="en_US"
	cursorHoverSelector={'a, button, [role="button"], .photo'}
>
	<script
		slot="head"
		type="application/ld+json"
		set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'CollectionPage',
			name: 'Fotos — Ángel Lavayen',
			description,
			url: canonicalURL,
			isPartOf: { '@type': 'WebSite', name: 'Ángel Lavayen', url: `${SITE_ORIGIN}/` }
		})}
	/>

	<style slot="head">
			:root {
				--site-pad: clamp(1.8rem, 4.8vw, 3rem);
			}

			* {
				box-sizing: border-box;
			}

			html,
			body {
				margin: 0;
				padding: 0;
				font-family: Inter, system-ui, -apple-system, sans-serif;
				background: #000;
				color: #f5f5f5;
			}

			body {
				cursor: none;
				min-height: 100svh;
				display: flex;
				flex-direction: column;
			}

			a {
				color: inherit;
				text-decoration: none;
			}

			.fotos-page {
				flex: 1;
				width: calc(100% - (var(--site-pad) * 2));
				margin: 0 auto;
				padding: 0;
			}

			.fotos-hero {
				position: relative;
				margin: 0;
				width: 100vw;
				margin-left: calc(50% - 50vw);
				margin-right: calc(50% - 50vw);
				height: 100svh;
				overflow: hidden;
				border-radius: 0;
				background: #000;
			}

			.fotos-hero img {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				object-fit: cover;
				object-position: center;
				filter: none;
			}

			/* Degradado negro debajo de la imagen (fade hacia el fondo). */
			.fotos-hero::after {
				content: '';
				position: absolute;
				left: 0;
				right: 0;
				bottom: 0;
				height: 35%;
				background: linear-gradient(
					to top,
					rgba(0, 0, 0, 0.95) 0%,
					rgba(0, 0, 0, 0.55) 45%,
					rgba(0, 0, 0, 0) 100%
				);
				pointer-events: none;
			}

			.fotos-hero-text {
				position: absolute;
				left: var(--site-pad);
				right: var(--site-pad);
				top: 50%;
				transform: translateY(-50%);
				padding: 0;
				font-family: 'Instrument Serif', Georgia, serif;
				color: #fff;
				font-weight: 400;
				letter-spacing: -0.02em;
				text-shadow: 0 12px 34px rgba(0, 0, 0, 0.6);
				z-index: 1;
				display: grid;
				align-content: center;
				gap: 0.55rem;
				text-align: left;
			}

			.fotos-hero-title {
				margin: 0;
				font-family: 'Instrument Serif', Georgia, serif;
				font-size: clamp(2.35rem, 6.5vw, 4rem);
				font-weight: 400;
				line-height: 1;
				letter-spacing: -0.02em;
			}

			.fotos-hero-subtitle {
				margin: 0;
				font-family: 'Instrument Serif', Georgia, serif;
				font-size: clamp(1.05rem, 1.9vw, 1.5rem);
				line-height: 1.2;
				font-weight: 400;
				letter-spacing: -0.01em;
				color: rgba(255, 255, 255, 0.88);
				max-width: 48ch;
			}

			.fotos-copy {
				padding: clamp(4.75rem, 9.5vw, 7.5rem) 0 clamp(4.75rem, 9.5vw, 7.5rem);
				max-width: none;
				margin: 0;
			}

			/* Párrafos largos: columna más estrecha y centrada en la página */
			.fotos-copy-body {
				max-width: min(100ch, 92%);
				margin-inline: auto;
			}

			.fotos-copy-body p {
				margin: 0 0 1.15rem;
				font-size: clamp(0.95rem, 1.05vw, 1.02rem);
				line-height: 1.65;
				color: rgba(245, 245, 245, 0.9);
				text-align: justify;
			}

			.fotos-copy-body p:last-of-type {
				margin-bottom: 0;
			}

			.fotos-copy p:last-child {
				margin-bottom: 0;
			}

			.fotos-grid {
				padding: clamp(2rem, 4vw, 3rem) 0 clamp(4rem, 12vw, 7rem);
			}

			.photo-grid {
				display: grid;
				grid-template-columns: 1fr;
				width: 100%;
				max-width: 100%;
				margin: 0 auto;
				gap: clamp(0.65rem, 1vw, 0.95rem);
			}

			/* Una columna en móvil, iPad (incl. horizontal ~1366px) y portátiles estrechos; dos columnas en pantallas amplias */
			@media (min-width: 1400px) {
				.photo-grid {
					grid-template-columns: repeat(2, minmax(0, 1fr));
					max-width: min(72rem, 88%);
				}
			}

			.photo {
				background: transparent;
				overflow: hidden;
				position: relative;
				display: block;
				aspect-ratio: 16 / 9;
			}

			.photo img {
				width: 100%;
				height: 100%;
				object-fit: cover;
				display: block;
				filter: none;
				transform: none;
				transition: none;
			}

			.photo:hover img {
				transform: none;
			}

			/* CTA final tras la galería (tipografía serif + SlideFrameLink, alineado a la izquierda) */
			.fotos-cta {
				margin-top: 0;
				padding: clamp(0.5rem, 1.2vw, 1rem) 0 clamp(3rem, 8vw, 5.5rem);
				background: #000;
				text-align: left;
			}

			.fotos-cta-copy {
				margin: 0 0 clamp(1.35rem, 2.5vw, 2rem);
				font-family: 'Instrument Serif', Georgia, serif;
				font-size: clamp(1.35rem, 2.2vw, 1.9rem);
				font-weight: 400;
				line-height: 1.22;
				letter-spacing: -0.015em;
				color: #fff;
				max-width: none;
			}

			.fotos-cta-copy .fotos-cta-line {
				display: block;
			}

			.fotos-cta-copy .fotos-cta-line + .fotos-cta-line {
				margin-top: 0.35em;
			}

			/* Segunda frase en una sola línea (en pantallas anchas); en móvil puede partirse */
			.fotos-cta-line--body {
				white-space: nowrap;
			}

			@media (max-width: 720px) {
				.fotos-cta-line--body {
					white-space: normal;
				}
			}

			.fotos-cta-copy em {
				font-style: italic;
			}

			@media (max-width: 640px) {
				.fotos-hero-subtitle {
					max-width: 34ch;
				}
			}

			@media (prefers-reduced-motion: reduce) {
				html {
					scroll-behavior: auto;
				}
			}

			@media (hover: none), (pointer: coarse) {
				body {
					cursor: auto;
				}
			}
		</style>
		<Header theme="dark" />

		<main class="fotos-page" id="main">
			<section class="fotos-hero" aria-label="Fotos">
				<img
					src={heroImg}
					alt="Fotografía en blanco y negro de un barco — imagen principal de la galería de Ángel Lavayen"
					loading="eager"
				/>
				<div class="fotos-hero-text">
					<h1 class="fotos-hero-title">¿Sigues aquí?</h1>
					<p class="fotos-hero-subtitle">Al final vas a tener buen gusto y todo.</p>
				</div>
			</section>

			<section class="fotos-copy" aria-label="Texto sobre la galeria">
				<div class="fotos-copy-body">
					<p>
						Ya que te has tomado la molestia de llegar hasta aquí, te diré la verdad: no es la cámara, es que
						sé dónde mirar (aunque la cámara también costó lo suyo).
					</p>

					<p>
						No, ya enserio… Mientras el resto del mundo hace fotos a su comida con un filtro de saturación al
						200%, yo prefiero buscar la geometría en un faro verde o la mirada existencial de una cebra que
						parece juzgarte más que tu cliente un lunes por la mañana.
					</p>

					<p>
						Desde una mariposa azul que se cree la protagonista de un documental de la BBC hasta medusas que
						parecen renderizadas con el mejor motor de iluminación de 2026. También me gusta que las líneas
						hablen así que si un faro no está perfectamente centrado o una carretera no tiene la curva
						perfecta… no me sirve. O por otro lado, esas parejas bajo la lluvia que parecen sacadas de una
						película francesa que nadie entiende pero en realidad a todos nos encanta y pensamos &quot;ooooh, que
						monos&quot;. O el vouyerismo de gente caminando en mercados que ni saben que acaban de formar parte de una
						de mis fotos.
					</p>

					<p>
						Te dejo disfrutarlas (o no).
					</p>
				</div>
			</section>

			<section class="fotos-grid" aria-label="Galeria de fotografias">
				<div class="photo-grid">
					{
						fotos.map((f) => (
							<div class="photo" aria-label={f.alt}>
								<img src={f.src} alt={f.alt} loading="lazy" />
							</div>
						))
					}
				</div>
			</section>

			<section class="fotos-cta" aria-label="Contacto">
				<p class="fotos-cta-copy">
					<span class="fotos-cta-line">Ya está bien ¿no?</span>
					<span class="fotos-cta-line fotos-cta-line--body">Deja de perder el tiempo <em>scrolleando</em> y contacta conmigo ;D</span>
				</p>
				<SlideFrameLink href="/contacto" label="¡Vamos!" />
			</section>
		</main>

		<Footer />
</BaseLayout>

