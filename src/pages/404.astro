---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { SITE_ORIGIN } from '../site';

const title = '404 — Esta pagina no existe | Angel Lavayen';
const description = 'La URL que buscas no esta en este portfolio. Vuelve al inicio o echa un vistazo al trabajo.';
const canonicalURL = new URL(Astro.url.pathname, SITE_ORIGIN).toString();
---

<BaseLayout
	title={title}
	description={description}
	canonicalURL={canonicalURL}
	robots="noindex, follow"
	showTwitter={false}
>
	<style slot="head">
		:root {
			--site-pad: clamp(1.8rem, 4.8vw, 3rem);
		}

		* {
			box-sizing: border-box;
		}

		html,
		body {
			margin: 0;
			padding: 0;
			font-family: Inter, system-ui, -apple-system, sans-serif;
			background: #000;
			color: #f5f5f5;
		}

		body {
			cursor: none;
			min-height: 100svh;
			display: flex;
			flex-direction: column;
		}

		a {
			color: inherit;
			text-decoration: none;
		}

		.notfound-main {
			flex: 1;
			width: calc(100% - (var(--site-pad) * 2));
			margin: 0 auto;
			padding: clamp(5.2rem, 14vw, 7.5rem) 0 clamp(4rem, 12vw, 7rem);
			display: grid;
			align-content: start;
			gap: clamp(1.25rem, 3vw, 2rem);
			max-width: 42rem;
		}

		.notfound-code {
			margin: 0;
			font-family: 'Instrument Serif', Georgia, serif;
			font-size: clamp(3.5rem, 12vw, 6.5rem);
			font-weight: 400;
			line-height: 0.95;
			letter-spacing: -0.03em;
			color: #fff;
		}

		.notfound-lead {
			margin: 0;
			font-family: 'Instrument Serif', Georgia, serif;
			font-size: clamp(1.35rem, 3.2vw, 1.85rem);
			font-weight: 400;
			line-height: 1.25;
			color: rgba(255, 255, 255, 0.92);
		}

		.notfound-lead em {
			font-style: italic;
		}

		.notfound-note {
			margin: 0.35rem 0 0;
			font-size: 0.82rem;
			line-height: 1.45;
			color: rgba(200, 200, 200, 0.5);
		}

		.notfound-actions {
			display: flex;
			flex-wrap: wrap;
			gap: 0.65rem 1rem;
			margin-top: 0.35rem;
		}

		.notfound-actions a {
			display: inline-flex;
			align-items: center;
			justify-content: center;
			padding: 0.58rem 1.1rem;
			font-size: 0.95rem;
			font-weight: 500;
			border-radius: 0.25rem;
			transition: transform 160ms ease, background-color 160ms ease, opacity 160ms ease;
		}

		.notfound-actions a.primary {
			background: #f2f2f2;
			color: #0a0a0a;
		}

		.notfound-actions a.primary:hover {
			background: #fff;
			transform: translateY(-1px);
		}

		.notfound-actions a.ghost {
			border: 1px solid rgba(255, 255, 255, 0.28);
			color: rgba(255, 255, 255, 0.92);
		}

		.notfound-actions a.ghost:hover {
			background: rgba(255, 255, 255, 0.06);
		}

		@media (prefers-reduced-motion: reduce) {
			html {
				scroll-behavior: auto;
			}

			.notfound-actions a {
				transition: none !important;
			}

			.notfound-actions a.primary:hover {
				transform: none;
			}
		}

		@media (hover: none), (pointer: coarse) {
			body {
				cursor: auto;
			}
		}

		.visually-hidden {
			position: absolute;
			width: 1px;
			height: 1px;
			padding: 0;
			margin: -1px;
			overflow: hidden;
			clip: rect(0, 0, 0, 0);
			white-space: nowrap;
			border: 0;
		}
	</style>

	<Header theme="dark" />

	<main class="notfound-main" id="main">
		<p class="notfound-code" aria-hidden="true">404</p>
		<h1 class="visually-hidden">Pagina no encontrada</h1>
		<p class="notfound-lead">
			Esta URL no existe. <em>O nunca existio</em> — el misterio va incluido en el pack gratuito.*
		</p>
		<p class="notfound-note">*No hay pack. Es un 404. La honestidad tambien es marca.</p>
		<div class="notfound-actions">
			<a class="primary" href="/">Volver al inicio</a>
			<a class="ghost" href="/works">Ver Works</a>
		</div>
	</main>

	<Footer />
</BaseLayout>
