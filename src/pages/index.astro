							</article>
							<article class="work-item">
								<a class="work-item-link" href={`/works/${workD.slug}/`}>
									<figure class="work-media">
										<img src={workD.img} alt={workD.alt} loading="lazy" />
									</figure>
									<div class="work-meta">
