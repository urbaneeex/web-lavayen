---
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import BaseLayout from '../layouts/BaseLayout.astro';
import { workProjects } from '../data/works';
import {
	OG_IMAGE_DEFAULT_HEIGHT,
	OG_IMAGE_DEFAULT_URL,
	OG_IMAGE_DEFAULT_WIDTH,
	SITE_ORIGIN
} from '../site';

const title = 'Proyectos de diseño gráfico y dirección de arte | Ángel Lavayen, Madrid';
const description =
	'Casos reales de Ángel Alejandro Lavayen Ruiz: branding, packaging, motion graphics, campañas, collages y diseño editorial. Director de arte y diseñador gráfico en Madrid.';
const canonicalURL = new URL(Astro.url.pathname, SITE_ORIGIN).toString();
---

<BaseLayout
	title={title}
	description={description}
	canonicalURL={canonicalURL}
	ogImage={OG_IMAGE_DEFAULT_URL}
	ogImageWidth={OG_IMAGE_DEFAULT_WIDTH}
	ogImageHeight={OG_IMAGE_DEFAULT_HEIGHT}
	ogLocaleAlternate="en_US"
>
	<script
		slot="head"
		type="application/ld+json"
		set:html={JSON.stringify({
			'@context': 'https://schema.org',
			'@type': 'CollectionPage',
			name: 'Proyectos — Ángel Lavayen',
			description,
			url: canonicalURL,
			isPartOf: { '@type': 'WebSite', name: 'Ángel Lavayen', url: `${SITE_ORIGIN}/` }
		})}
	/>

	<style slot="head">
		:root {
			--site-pad: clamp(1.8rem, 4.8vw, 3rem);
		}

		* {
			box-sizing: border-box;
		}

		html,
		body {
			margin: 0;
			padding: 0;
			font-family: Inter, system-ui, -apple-system, sans-serif;
			background: #000;
			color: #f5f5f5;
		}

		body {
			cursor: none;
			min-height: 100svh;
			display: flex;
			flex-direction: column;
		}

		a {
			color: inherit;
			text-decoration: none;
		}

		.work-page {
			flex: 1;
			width: calc(100% - (var(--site-pad) * 2));
			margin: 0 auto;
			padding: clamp(5.2rem, 14vw, 7.5rem) 0 clamp(4rem, 12vw, 7rem);
		}

		.work-page-title {
			margin: 0 0 clamp(1.75rem, 3.5vw, 2.75rem);
			font-family: 'Instrument Serif', Georgia, serif;
			font-size: clamp(2.35rem, 6.5vw, 4rem);
			font-weight: 400;
			line-height: 1;
			letter-spacing: -0.02em;
			color: #fff;
		}

		.work {
			display: grid;
			grid-template-columns: repeat(2, minmax(0, 1fr));
			gap: clamp(0.7rem, 1.2vw, 1.2rem);
		}

		.work-item {
			display: grid;
			gap: 0.58rem;
		}

		.work-media {
			margin: 0;
			aspect-ratio: 16 / 11;
			background: #111;
			overflow: hidden;
		}

		.work-media img {
			width: 100%;
			height: 100%;
			object-fit: cover;
			display: block;
			transition: transform 220ms ease;
		}

		.work-item:hover .work-media img {
			transform: scale(1.015);
		}

		.work-item-link {
			display: grid;
			gap: 0.58rem;
			color: inherit;
			text-decoration: none;
		}

		.work-item-link:focus-visible {
			outline: 2px solid rgba(255, 255, 255, 0.45);
			outline-offset: 4px;
		}

		.work-meta {
			display: grid;
			gap: 0.25rem;
		}

		.work-year {
			width: fit-content;
			padding: 0.08rem 0.38rem;
			font-size: 0.78rem;
			color: rgba(239, 239, 239, 0.9);
			border: 1px solid rgba(255, 255, 255, 0.2);
			border-radius: 0.18rem;
			line-height: 1.2;
		}

		.work-item h2 {
			margin: 0;
			font-size: clamp(1.25rem, 1.55vw, 1.75rem);
			font-weight: 500;
			letter-spacing: -0.01em;
		}

		.work-item p {
			margin: 0;
			font-size: 1rem;
			color: rgba(241, 241, 241, 0.78);
		}

		@media (max-width: 640px) {
			.work {
				grid-template-columns: 1fr;
			}
		}

		@media (prefers-reduced-motion: reduce) {
			html {
				scroll-behavior: auto;
			}

			.work-media img {
				transition: none !important;
			}

			.work-item:hover .work-media img {
				transform: none;
			}
		}

		@media (hover: none), (pointer: coarse) {
			body {
				cursor: auto;
			}
		}
	</style>

	<Header theme="dark" />

	<main class="work-page" id="main">
		<h1 class="work-page-title">Works</h1>

		<section class="work-showcase" aria-label="Proyectos">
			<div class="work">
				{
					workProjects.map((p) => (
						<article class="work-item">
							<a class="work-item-link" href={`/works/${p.slug}/`}>
								<figure class="work-media">
									<img src={p.img} alt={p.alt} loading="lazy" />
								</figure>
								<div class="work-meta">
									<span class="work-year">{p.year}</span>
									<h2>{p.title}</h2>
									{p.desc ? <p>{p.desc}</p> : null}
								</div>
							</a>
						</article>
					))
				}
			</div>
		</section>
	</main>

	<Footer />
</BaseLayout>
