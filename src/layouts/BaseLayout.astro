---
import SiteCursor from '../components/SiteCursor.astro';
import { SITE_ORIGIN } from '../site';

interface Props {
	title: string;
	description: string;
	/** Si no se pasa, se calcula con SITE_ORIGIN + pathname actual */
	canonicalURL?: string;
	robots?: string;
	lang?: string;
	ogType?: 'website' | 'article';
	ogSiteName?: string;
	ogTitle?: string;
	ogDescription?: string;
	ogUrl?: string;
	ogImage?: string | undefined;
	/** Dimensiones OG cuando se conocen (mejor para redes sociales). */
	ogImageWidth?: number;
	ogImageHeight?: number;
	/** og:locale (p. ej. en_US en /en/). */
	ogLocale?: string;
	/** Idioma alternativo del sitio (og:locale:alternate). */
	ogLocaleAlternate?: string;
	twitterCard?: 'summary' | 'summary_large_image';
	keywords?: string;
	author?: string;
	/** Pesos Inter en la query de Google Fonts (p. ej. "400;500;600") */
	interWeights?: string;
	showTwitter?: boolean;
	showOgSiteName?: boolean;
	showCursor?: boolean;
	cursorHoverSelector?: string;
}

const {
	title,
	description,
	canonicalURL: canonicalURLProp,
	robots = 'index, follow',
	lang = 'es',
	ogType = 'website',
	ogSiteName = 'Ángel Lavayen',
	ogTitle,
	ogDescription,
	ogUrl,
	ogImage,
	ogImageWidth,
	ogImageHeight,
	ogLocale = 'es_ES',
	ogLocaleAlternate,
	twitterCard = 'summary_large_image',
	keywords,
	author,
	interWeights = '400;500;600;700',
	showTwitter = true,
	showOgSiteName = true,
	showCursor = true,
	cursorHoverSelector = 'a, button, [role="button"], .work-item-link, .featured-work-link, .photo'
} = Astro.props;

const canonicalURL = canonicalURLProp ?? new URL(Astro.url.pathname, SITE_ORIGIN).toString();
const resolvedOgTitle = ogTitle ?? title;
const resolvedOgDesc = ogDescription ?? description;
const resolvedOgUrl = ogUrl ?? canonicalURL;
const fontHref = `https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Inter:wght@${interWeights}&display=swap`;
---

<!doctype html>
<html lang={lang}>
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<meta name="description" content={description} />
		{keywords ? <meta name="keywords" content={keywords} /> : null}
		{author ? <meta name="author" content={author} /> : null}
		<meta name="robots" content={robots} />
		<link rel="canonical" href={canonicalURL} />

		<meta property="og:type" content={ogType} />
		<meta property="og:locale" content={ogLocale} />
		{ogLocaleAlternate ? <meta property="og:locale:alternate" content={ogLocaleAlternate} /> : null}
		{showOgSiteName ? <meta property="og:site_name" content={ogSiteName} /> : null}
		<meta property="og:title" content={resolvedOgTitle} />
		<meta property="og:description" content={resolvedOgDesc} />
		<meta property="og:url" content={resolvedOgUrl} />
		{
			ogImage ? (
				<>
					<meta property="og:image" content={ogImage} />
					{ogImageWidth && ogImageHeight ? (
						<>
							<meta property="og:image:width" content={String(ogImageWidth)} />
							<meta property="og:image:height" content={String(ogImageHeight)} />
						</>
					) : null}
				</>
			) : null
		}

		{
			showTwitter ? (
				<>
					<meta name="twitter:card" content={twitterCard} />
					<meta name="twitter:title" content={resolvedOgTitle} />
					<meta name="twitter:description" content={resolvedOgDesc} />
					{ogImage ? <meta name="twitter:image" content={ogImage} /> : null}
				</>
			) : null
		}

		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href={fontHref} rel="stylesheet" />

		<slot name="head" />
	</head>
	<body>
		<slot />
		{showCursor ? <SiteCursor hoverSelector={cursorHoverSelector} /> : null}
	</body>
</html>
